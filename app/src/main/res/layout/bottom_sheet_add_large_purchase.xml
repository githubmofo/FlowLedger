<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_glass_card">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <View
            android:id="@+id/handle"
            android:layout_width="48dp"
            android:layout_height="6dp"
            android:background="#1AFFFFFF"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Large Purchase"
            android:textColor="?attr/colorOnSurface"
            android:textSize="24sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="-0.01"
            android:layout_marginTop="28dp"
            app:layout_constraintTop_toBottomOf="@id/handle"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="14sp"
            android:fontFamily="sans-serif"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent" />

        <EditText
            android:id="@+id/etTitleInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="What did you buy? (e.g. iPhone 15)"
            android:textColorHint="?attr/colorOnSurfaceVariant"
            android:textColor="?attr/colorOnSurface"
            android:textSize="18sp"
            android:background="@drawable/bg_glass_card"
            android:padding="16dp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/tvDate" />

        <!-- Amount Input -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_glass_card"
            android:padding="20dp"
            app:layout_constraintTop_toBottomOf="@id/etTitleInput">

            <TextView
                android:id="@+id/tvCurrency"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹"
                android:textColor="?attr/colorPrimary"
                android:textSize="32sp"
                android:fontFamily="sans-serif-medium"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <EditText
                android:id="@+id/etAmount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:hint="0.00"
                android:textColorHint="?attr/colorOnSurfaceVariant"
                android:textColor="?attr/colorOnSurface"
                android:textSize="48sp"
                android:fontFamily="sans-serif-medium"
                android:background="@android:color/transparent"
                android:inputType="numberDecimal"
                android:layout_marginStart="12dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/tvCurrency"
                app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/tvPurchaseTypeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PURCHASE TYPE"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:fontFamily="sans-serif-medium"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/layoutAmount"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/cgPurchaseType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:layout_constraintTop_toBottomOf="@id/tvPurchaseTypeLabel"
            app:layout_constraintStart_toStartOf="parent">
            <com.google.android.material.chip.Chip
                android:id="@+id/chipOneTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="One-time"
                style="@style/Widget.Material3.Chip.Filter" />
            <com.google.android.material.chip.Chip
                android:id="@+id/chipEmi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EMI"
                style="@style/Widget.Material3.Chip.Filter" />
            <com.google.android.material.chip.Chip
                android:id="@+id/chipLoan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loan"
                style="@style/Widget.Material3.Chip.Filter" />
        </com.google.android.material.chip.ChipGroup>

        <!-- Dynamic EMI Fields -->
        <LinearLayout
            android:id="@+id/layoutEmiFields"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_glass_card"
            android:padding="16dp"
            app:layout_constraintTop_toBottomOf="@id/cgPurchaseType">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EMI Details"
                android:textColor="?attr/colorPrimary"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/etEmiAmount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="EMI Amount (per month)"
                android:inputType="numberDecimal"
                android:textColor="?attr/colorOnSurface"
                android:textSize="16sp"
                android:padding="12dp"
                android:background="@null" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1AFFFFFF" android:layout_marginVertical="4dp"/>

            <EditText
                android:id="@+id/etEmiMonths"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Number of Months (Tenure)"
                android:inputType="number"
                android:textColor="?attr/colorOnSurface"
                android:textSize="16sp"
                android:padding="12dp"
                android:background="@null" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Save Purchase"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            app:cornerRadius="32dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="16dp"
            app:layout_constraintTop_toBottomOf="@id/layoutEmiFields"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
